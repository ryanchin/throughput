# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (LLM grading + AI course generation)
OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Site
NEXT_PUBLIC_SITE_URL=

# Bunny.net Stream (video hosting)
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=
NEXT_PUBLIC_BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_CDN_HOSTNAME=
BUNNY_STREAM_TOKEN_SECRET=

# Upstash Redis (rate limiting — optional, degrades gracefully if missing)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (email delivery for daily digest)
RESEND_API_KEY=

# Cron secret (authenticates Vercel Cron requests)
CRON_SECRET=

# Test (separate Supabase project for integration tests)
SUPABASE_TEST_URL=
SUPABASE_TEST_SERVICE_ROLE_KEY=
